{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pika",
  "version": "0.1.0",
  "identifier": "dev.pika.editor",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "pika",
        "width": 1200,
        "height": 800,
        "minWidth": 640,
        "minHeight": 480,
        "resizable": true,
        "visible": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: asset: http://asset.localhost http://pika-asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "publisher": "pika",
    "copyright": "Copyright (c) 2026 pika contributors",
    "category": "Productivity",
    "shortDescription": "Windows 向け超軽量 Markdown/HTML エディタ",
    "longDescription": "AIエージェントの出力物を確認・差分レビューする伴走ツール。Windows 11 x64 専用・UI は日本語。",
    "license": "MIT",
    "licenseFile": "../LICENSE",
    "resources": {
      "../assets/THIRD_PARTY_NOTICES": "THIRD_PARTY_NOTICES.txt"
    },
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["Japanese"],
        "displayLanguageSelector": false,
        "installerHooks": "nsis/hooks.nsh"
      }
    }
  }
}
