{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "_vcpkg-base",
      "hidden": true,
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_TARGET_TRIPLET": "x64-windows-static",
        "VCPKG_HOST_TRIPLET": "x64-windows-static"
      }
    },
    {
      "name": "x64-core-test",
      "displayName": "x64 core-test（wx 非依存。core/+util と gtest のみ）",
      "description": "重量依存（wx/WebView2）を含まない軽量プリセット。pika_core と pika_tests を構成・ビルド・テストする",
      "inherits": "_vcpkg-base",
      "binaryDir": "${sourceDir}/build/x64-core-test",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PIKA_BUILD_GUI": "OFF",
        "PIKA_BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "tests"
      }
    },
    {
      "name": "x64-release",
      "displayName": "x64 Release（wx を含む GUI 本体）",
      "description": "pika GUI exe を含む完全構成。初回の重量依存ビルドは時間がかかる",
      "inherits": "_vcpkg-base",
      "binaryDir": "${sourceDir}/build/x64-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "PIKA_BUILD_GUI": "ON",
        "PIKA_BUILD_TESTS": "ON",
        "VCPKG_MANIFEST_FEATURES": "gui;tests"
      }
    },
    {
      "name": "x64-debug",
      "displayName": "x64 Debug（wx を含む GUI 本体）",
      "inherits": "x64-release",
      "binaryDir": "${sourceDir}/build/x64-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "x64-core-test",
      "configurePreset": "x64-core-test",
      "configuration": "Release"
    },
    {
      "name": "x64-release",
      "configurePreset": "x64-release",
      "configuration": "Release"
    }
  ],
  "testPresets": [
    {
      "name": "x64-core-test",
      "configurePreset": "x64-core-test",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      },
      "execution": {
        "noTestsAction": "error",
        "stopOnFailure": false
      }
    },
    {
      "name": "x64-release",
      "configurePreset": "x64-release",
      "configuration": "Release",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
